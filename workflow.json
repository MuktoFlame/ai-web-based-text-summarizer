{
  "name": "AI Text Processing Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ai-text-processing",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "a1111111-1111-4111-8111-111111111111",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "ai-text-processing"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyse the TEXT below and respond with a single JSON object only. No markdown, no code fences, no commentary outside the JSON.\n\nShape:\n{\n  \"summary\": \"a concise 2 to 4 sentence summary\",\n  \"key_points\": [\"point 1\", \"point 2\", \"point 3\"]\n}\n\nThe key_points array must contain exactly 3 short, informative bullet points.\n\nTEXT:\n{{ $('Webhook').item.json.body.text }}",
        "options": {
          "systemMessage": "You are an expert at summarising text and extracting key points. Always respond with a single strict JSON object only — no preface, no markdown, no code fences."
        }
      },
      "id": "a2222222-2222-4222-8222-222222222222",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [460, 300]
    },
    {
      "parameters": {
        "modelName": "models/gemini-1.5-flash",
        "options": {}
      },
      "id": "a3333333-3333-4333-8333-333333333333",
      "name": "Google Gemini Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [360, 520]
    },
    {
      "parameters": {
        "sessionIdType": "customKey",
        "sessionKey": "={{ $('Webhook').item.json.body.session_id }}"
      },
      "id": "a4444444-4444-4444-8444-444444444444",
      "name": "Simple Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1.3,
      "position": [560, 520]
    },
    {
      "parameters": {
        "jsCode": "const webhook = $('Webhook').item.json.body || {};\nconst rawOutput = ($json.output || $json.text || '').toString();\n\nlet summary = '';\nlet keyPoints = [];\n\ntry {\n  let jsonStr = rawOutput.trim();\n  jsonStr = jsonStr.replace(/^```(?:json)?\\s*/i, '').replace(/\\s*```$/, '');\n  const firstBrace = jsonStr.indexOf('{');\n  const lastBrace = jsonStr.lastIndexOf('}');\n  if (firstBrace !== -1 && lastBrace !== -1) {\n    jsonStr = jsonStr.slice(firstBrace, lastBrace + 1);\n  }\n  const parsed = JSON.parse(jsonStr);\n  summary = (parsed.summary || '').toString().trim();\n  keyPoints = parsed.key_points || parsed.keyPoints || parsed.points || [];\n} catch (e) {\n  summary = rawOutput;\n  keyPoints = [];\n}\n\nconst keyPointsText = keyPoints.map((p, i) => (i + 1) + '. ' + p).join('\\n');\n\nreturn [{\n  json: {\n    session_id: webhook.session_id || '',\n    email: webhook.email || '',\n    text: webhook.text || '',\n    source: webhook.source || 'text',\n    source_url: webhook.source_url || '',\n    summary,\n    key_points: keyPoints,\n    key_points_text: keyPointsText,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "a5555555-5555-4555-8555-555555555555",
      "name": "Build Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 300]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "",
          "mode": "list",
          "cachedResultName": "<-- Select your own Google Sheet after import"
        },
        "sheetName": {
          "__rl": true,
          "value": "",
