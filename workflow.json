        "sendTo": "={{ $('Build Record').item.json.email }}",
        "subject": "=Your AI Summary (Session {{ $('Build Record').item.json.session_id }})",
        "emailType": "text",
        "message": "=Hi,\n\nHere is the AI-generated summary of the text you submitted.\n\nSession ID: {{ $('Build Record').item.json.session_id }}\n\n=== Summary ===\n{{ $('Build Record').item.json.summary }}\n\n=== Key Points ===\n{{ $('Build Record').item.json.key_points_text }}\n\n— AI Text Processing Workflow",
        "options": {}
