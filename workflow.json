            "Session ID": "={{ $json.session_id }}",
            "Email": "={{ $json.email }}",
            "Source": "={{ $json.source }}",
            "Source URL": "={{ $json.source_url }}",
            "Original Text": "={{ $json.text }}",
            "Summary": "={{ $json.summary }}",
            "Key Points": "={{ $json.key_points_text }}",
            "Timestamp": "={{ $json.timestamp }}"
          },
          "matchingColumns": [],
          "schema": [
            {"id": "Session ID", "displayName": "Session ID", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true},
